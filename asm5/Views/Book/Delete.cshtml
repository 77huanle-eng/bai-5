@model asm5.Models.Book

@{
    ViewData["Title"] = "Xóa sách";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-danger text-white py-3 text-center">
                    <h3 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Xác Nhận Xóa Sách</h3>
                </div>
                <div class="card-body p-4 bg-white text-center">
                    <h5 class="text-danger fw-bold mb-4">Bạn có chắc chắn muốn xóa cuốn sách này khỏi hệ thống?</h5>
                    
                    <!-- Book Summary Card -->
                    <div class="d-flex align-items-center justify-content-start border rounded-3 p-3 bg-light mb-4 text-start">
                        <img src="~/Content/ImageBooks/@Model.Image" alt="@Model.Title" class="rounded border me-3" style="width: 80px; height: 100px; object-fit: contain; background-color: #fff;" />
                        <div>
                            <h6 class="fw-bold mb-1 text-dark">@Model.Title</h6>
                            <div class="text-muted small mb-1"><i class="bi bi-person-fill"></i> Tác giả: @Model.Author</div>
                            <div class="text-muted small mb-1"><i class="bi bi-tag-fill"></i> Thể loại: @Model.Category?.CategoryName</div>
                            <div class="text-danger fw-bold fs-6">Giá bán: @Model.Price.ToString("N0") VND</div>
                        </div>
                    </div>

                    <!-- Confirm Form -->
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="BookId" />
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold rounded-3">
                                <i class="bi bi-trash-fill me-1"></i> Xác nhận xóa
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg fw-bold rounded-3">
                                Hủy bỏ, quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
