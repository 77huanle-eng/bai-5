@model IEnumerable<asm5.Models.Book>

@{
    ViewData["Title"] = "Trang Chủ - Nhà Sách";
    var categories = ViewBag.Categories as IEnumerable<asm5.Models.Category>;
    int? selectedCategoryId = ViewBag.SelectedCategoryId as int?;
}

<div class="row mt-4">
    <!-- Sidebar for Categories -->
    <div class="col-md-3 mb-4">
        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
            <div class="card-header bg-dark text-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-tag-fill me-2"></i>Chủ đề</h5>
            </div>
            <div class="list-group list-group-flush">
                <!-- 'All' Category item -->
                <a asp-action="Index" asp-route-categoryId="" 
                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 px-4 @(selectedCategoryId == null ? "active bg-primary border-primary" : "")">
                    <span class="fw-medium">Tất cả</span>
                    <span class="badge bg-secondary rounded-pill">@categories?.Sum(c => c.Books.Count)</span>
                </a>
                
                @if (categories != null)
                {
                    foreach (var category in categories)
                    {
                        bool isActive = selectedCategoryId == category.CategoryId;
                        <a asp-action="Index" asp-route-categoryId="@category.CategoryId" 
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 px-4 @(isActive ? "active bg-primary border-primary" : "")">
                            <span class="fw-medium">@category.CategoryName</span>
                            <span class="badge @(isActive ? "bg-white text-primary" : "bg-primary") rounded-pill">@category.Books.Count</span>
                        </a>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Main Content for Books -->
    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-dark m-0">Danh Sách Sách</h2>
            <a asp-action="Create" class="btn btn-success px-4 py-2 rounded-pill shadow-sm fw-bold">
                <i class="bi bi-plus-lg me-2"></i>Thêm mới
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-warning text-center py-5 rounded-3 shadow-sm" role="alert">
                <i class="bi bi-exclamation-triangle-fill display-4 text-warning mb-3"></i>
                <h4 class="fw-bold">Không tìm thấy cuốn sách nào!</h4>
                <p class="text-muted mb-0">Không có cuốn sách nào thuộc chủ đề được chọn.</p>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 rounded-3 book-card transition-all duration-300">
                            <!-- Image container with fixed height and centering -->
                            <div class="position-relative overflow-hidden bg-light d-flex align-items-center justify-content-center" style="height: 320px;">
                                <img src="~/Content/ImageBooks/@item.Image" class="img-fluid book-cover-img" style="max-height: 280px; object-fit: contain;" alt="@item.Title" />
                                <span class="position-absolute top-0 start-0 m-3 badge bg-dark opacity-90 py-2 px-3 rounded-pill">
                                    @item.Category?.CategoryName
                                </span>
                            </div>
                            <div class="card-body p-4 d-flex flex-column">
                                <h5 class="card-title fw-bold text-dark text-truncate-2 mb-2" style="min-height: 48px;" title="@item.Title">
                                    @item.Title
                                </h5>
                                <p class="card-text text-muted mb-3 small">
                                    <i class="bi bi-person-fill me-1"></i>Tác giả: <span class="fw-medium">@item.Author</span>
                                </p>
                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    <span class="fs-5 fw-bold text-danger">@item.Price.ToString("N0") VND</span>
                                    <div class="btn-group gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.BookId" class="btn btn-outline-secondary btn-sm rounded-2 px-2 py-1" title="Sửa">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.BookId" class="btn btn-outline-primary btn-sm rounded-2 px-2 py-1" title="Chi tiết">
                                            Chi tiết
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.BookId" class="btn btn-outline-danger btn-sm rounded-2 px-2 py-1" title="Xóa">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
