@model asm5.Models.Book

@{
    ViewData["Title"] = Model.Title + " - Chi tiết sách";
    decimal originalPrice = Math.Round(Model.Price * 1.3m / 1000m) * 1000m; // Generate a dummy higher original price
    int discountPercent = 23; // standard discount shown in slide
}

<div class="container mt-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="text-decoration-none">@Model.Category?.CategoryName</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-lg p-4 rounded-4 bg-white">
        <div class="row g-5">
            <!-- Left side: Book Image -->
            <div class="col-md-5 col-lg-4 text-center">
                <div class="p-3 border rounded-3 bg-light d-flex align-items-center justify-content-center shadow-sm" style="min-height: 400px;">
                    <img src="~/Content/ImageBooks/@Model.Image" class="img-fluid rounded shadow-sm book-details-img" style="max-height: 380px; object-fit: contain;" alt="@Model.Title" />
                </div>
            </div>

            <!-- Right side: Book Details -->
            <div class="col-md-7 col-lg-8 d-flex flex-column">
                <h1 class="fw-bold text-dark mb-3 lh-sm fs-2">@Model.Title</h1>
                
                <!-- Metadata Row -->
                <div class="row g-2 mb-3 small text-muted">
                    <div class="col-sm-6">
                        <span class="me-2">Nhà cung cấp:</span><strong class="text-dark">Nhà sách Fahasa</strong>
                    </div>
                    <div class="col-sm-6">
                        <span class="me-2">Tác giả:</span><strong class="text-dark">@Model.Author</strong>
                    </div>
                    <div class="col-sm-6">
                        <span class="me-2">Nhà xuất bản:</span><strong class="text-dark">NXB Giáo Dục</strong>
                    </div>
                    <div class="col-sm-6">
                        <span class="me-2">Thể loại:</span><strong class="text-dark">@Model.Category?.CategoryName</strong>
                    </div>
                </div>

                <!-- Star Ratings -->
                <div class="d-flex align-items-center mb-4">
                    <div class="text-warning me-2 fs-5">
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                    </div>
                    <span class="text-muted small border-start ps-2">(79 đánh giá)</span>
                </div>

                <!-- Price Box -->
                <div class="bg-light p-4 rounded-3 mb-4 d-flex align-items-baseline gap-3 flex-wrap">
                    <span class="fs-1 fw-bold text-danger">@Model.Price.ToString("N0") đ</span>
                    <span class="text-decoration-line-through text-muted fs-5">@originalPrice.ToString("N0") đ</span>
                    <span class="badge bg-danger fs-6 py-2 px-3 rounded-pill">-@discountPercent%</span>
                </div>

                <!-- Shipping and Policy Section -->
                <div class="card border-0 bg-light p-3 rounded-3 mb-4 small text-dark">
                    <div class="d-flex mb-2">
                        <i class="bi bi-truck text-primary fs-5 me-3"></i>
                        <div>
                            <div class="fw-bold">Thời gian giao hàng:</div>
                            <div class="text-muted">Giao nhanh toàn quốc (1-3 ngày làm việc)</div>
                        </div>
                    </div>
                    <hr class="my-2 text-muted">
                    <div class="d-flex">
                        <i class="bi bi-arrow-counterclockwise text-success fs-5 me-3"></i>
                        <div>
                            <div class="fw-bold">Chính sách đổi trả:</div>
                            <div class="text-muted">Đổi trả sản phẩm miễn phí trong 30 ngày</div>
                        </div>
                    </div>
                </div>

                <!-- Quantity Control -->
                <div class="d-flex align-items-center mb-4 gap-3">
                    <span class="fw-bold text-dark">Số lượng:</span>
                    <div class="input-group" style="width: 140px;">
                        <button class="btn btn-outline-secondary" type="button" onclick="changeQty(-1)">-</button>
                        <input type="text" class="form-control text-center fw-bold" id="qtyInput" value="1" readonly>
                        <button class="btn btn-outline-secondary" type="button" onclick="changeQty(1)">+</button>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="d-flex gap-3 mb-4 flex-wrap">
                    <button class="btn btn-outline-danger btn-lg px-4 py-3 fw-bold rounded-3 flex-grow-1 flex-md-grow-0 d-flex align-items-center justify-content-center gap-2" style="border-width: 2px;">
                        <i class="bi bi-cart-plus-fill fs-5"></i> Thêm vào giỏ hàng
                    </button>
                    <button class="btn btn-danger btn-lg px-5 py-3 fw-bold rounded-3 flex-grow-1 flex-md-grow-0 text-uppercase shadow-sm">
                        Mua ngay
                    </button>
                </div>

                <!-- Admin Action Links -->
                <div class="d-flex gap-2 mt-auto pt-3 border-top">
                    <a asp-action="Edit" asp-route-id="@Model.BookId" class="btn btn-warning fw-bold px-4 py-2">
                        <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa
                    </a>
                    <a asp-action="Index" class="btn btn-secondary px-4 py-2">
                        Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>

        <!-- Description Box -->
        <div class="mt-5 pt-4 border-top">
            <h3 class="fw-bold text-dark mb-3"><i class="bi bi-file-text-fill text-danger me-2"></i>Mô tả sản phẩm</h3>
            <p class="text-secondary lh-lg text-justify fs-6" style="white-space: pre-line;">
                @Model.Description
            </p>
        </div>
    </div>
</div>

<script>
    function changeQty(amount) {
        var input = document.getElementById("qtyInput");
        var val = parseInt(input.value) + amount;
        if (val < 1) val = 1;
        input.value = val;
    }
</script>
