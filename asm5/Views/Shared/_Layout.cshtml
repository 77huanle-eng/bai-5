<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nhà Sách Trực Tuyến</title>
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/asm5.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-dark bg-dark border-bottom shadow-sm py-3 mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold fs-4 text-warning" asp-controller="Book" asp-action="Index">
                    <i class="bi bi-book-half me-2"></i>NHÀ SÁCH
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-md-inline-flex justify-content-between">
                    <ul class="navbar-nav me-auto mb-2 mb-md-0">
                        <li class="nav-item">
                            <a class="nav-link text-white fw-medium" asp-controller="Book" asp-action="Index">Trang chủ</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav gap-2">
                        <li class="nav-item">
                            <a class="nav-link text-white-50" href="#"><i class="bi bi-person-plus-fill me-1"></i>Đăng ký</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white-50" href="#"><i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập</a>
                        </li>
                        <li class="nav-item ms-md-2">
                            <a class="btn btn-outline-warning d-flex align-items-center gap-2 px-3" href="#">
                                <i class="bi bi-cart3"></i> Giỏ hàng <span class="badge bg-danger rounded-pill">0</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light py-4 mt-auto">
        <div class="container text-center">
            <div class="text-dark fw-bold mb-2">NHÀ SÁCH TRỰC TUYẾN - ASM5</div>
            <div class="small">&copy; 2026 - Bản quyền thuộc về Lập Trình Web</div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
