@model IEnumerable<bai5.Models.Student>

@{
    ViewData["Title"] = "Danh sách Sinh viên";
}

<div class="container mt-5">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white text-center py-3">
            <h3 class="m-0 text-uppercase fw-bold">Danh Sách Sinh Viên </h3>
        </div>
        <div class="card-body p-4">
            <table class="table table-striped table-hover table-bordered alignment-middle m-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th style="width: 15%">Mã SV</th>
                        <th style="width: 25%">Họ</th>
                        <th style="width: 25%">Tên</th>
                        <th style="width: 35%">Tên Lớp </th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold">@item.StudentId</td>
                                <td>@item.LastName</td>
                                <td>@item.FirstName</td>
                                <td class="text-center text-danger fw-bold">
                                    @(item.Grade != null ? item.Grade.GradeName : "Chưa xếp lớp")
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-3">Không có dữ liệu sinh viên.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>