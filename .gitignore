## Ignore Visual Studio temporary files, build results, and files generated by popular Visual Studio add-ons.
# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/xamarin Studio)
*.userprefs

# Mono auto generated files
*.pidb

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/
[Log]/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create toplevel directories there
#TopLevel/

# MSTest ResolveAssemblyReference cache
*.sublime-workspace

# MSBuild files
*-MSBuild*.html
*-MSBuild*.xml

# Visual Studio Code project and workspace directories
.vscode/

# Rider project files
.idea/

# Local History for Visual Studio Code
.history/
